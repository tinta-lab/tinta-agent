# ─── Required ─────────────────────────────────────────────────────────────────
# Client UUID from DB (clients.id) — generated by /tinta-core/provision/:clientId
TINTA_CLIENT_ID=<uuid>

# JWT signed with AGENT_JWT_SECRET — generated by /tinta-core/provision/:clientId
TINTA_AGENT_TOKEN=<jwt>

# ─── Tinta Core WebSocket ──────────────────────────────────────────────────────
TINTA_CORE_WS=wss://api.tinta-lab.de/tinta/ws

# ─── Home Assistant connection ────────────────────────────────────────────────
# Option A: HA Add-on (agent runs inside HAOS via supervisor)
#   HA_HOST=homeassistant   ← triggers supervisor proxy mode
#   SUPERVISOR_TOKEN is auto-injected by the supervisor

# Option B: Standalone (Docker / PM2 on separate machine)
#   Use Cloudflare tunnel hostname:
#   HA_HOST=mueller.tinta-lab.de
#   HA_PORT=443
#   HA_SSL=true
#   SUPERVISOR_TOKEN=<HA Long-Lived Access Token>  (HA → Profile → Tokens)

HA_HOST=homeassistant
# HA_PORT=80        # only needed for standalone
# HA_SSL=false      # only needed for standalone
# SUPERVISOR_TOKEN= # auto-injected in Add-on mode; required for standalone

# ─── Optional ─────────────────────────────────────────────────────────────────
# Public URL shown in client's HA dashboard (for Cloudflare tunnel)
TINTA_EXTERNAL_URL=https://mueller.tinta-lab.de

# Default support password (overridden per-grant cycle)
TINTA_SUPPORT_PASSWORD=TintaLab2026!
