# ── Шаблон для нового клиента ─────────────────────────────────────────────────
# Скопировать: cp .env.example SUBDOMAIN.env
# Заполнить значениями из вывода provision-client.sh или Admin → Agents → Новый клиент

# Из результата провиженинга:
TINTA_CLIENT_ID=<uuid из поля clientId>
TINTA_AGENT_TOKEN=<токен из поля agentToken>

# Не меняется (общий для всех клиентов):
TINTA_CORE_WS=wss://api.tinta-lab.de/tinta/ws

# ── Режим A: HA Add-on (агент внутри Home Assistant) ─────────────────────────
# HA_HOST=homeassistant
# SUPERVISOR_TOKEN автоматически подставляется HA Supervisor

# ── Режим B: Standalone через Cloudflare tunnel ───────────────────────────────
HA_HOST=SUBDOMAIN.tinta-lab.de
HA_PORT=443
HA_SSL=true
TINTA_EXTERNAL_URL=https://SUBDOMAIN.tinta-lab.de
SUPERVISOR_TOKEN=<Long-Lived Token из HA → Профиль → Токены доступа>
